---
const cdnBase = 'https://imagedelivery.net/-sPAUAWeA405NiWJ0SNIQA/c4c747b3-4318-4863-779e-09c52aea0700';
const imgSrc = `${cdnBase}/public`;
---

<div class="relative w-full overflow-hidden rounded-2xl border border-gold/20 shadow-2xl shadow-gold/10">
  <picture>
    <img
      src={imgSrc}
      alt="itsyou.ooo — Only you can change you"
      class="w-full h-auto object-cover"
      loading="eager"
      decoding="async"
      width="1200"
      height="630"
    />
  </picture>
  <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/30 to-transparent" aria-hidden="true"></div>

  <!-- Overlay text -->
  <div class="absolute bottom-0 left-0 right-0 p-8 md:p-12">
    <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight text-cream mb-4">
      itsyou<span class="text-gold">.ooo</span>
    </h1>
    <p class="text-lg md:text-xl text-cream-muted max-w-2xl font-sans">
      Only you can change you. Only concern yourself with things you can change.
    </p>
  </div>
</div>
